# =============================================
# Personal Blog 后端环境变量配置示例
# =============================================
# 复制此文件为 .env 并填写实际值
# 注意：生产环境请使用 Cloudflare Dashboard 配置 Secrets
# =============================================

# JWT 密钥（必需）
# 请使用 32 位以上的随机字符串
# 生成命令: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# 文章密码访问密钥（可选）
# 用于加密文章密码访问 Token
POST_PASSWORD_SECRET=your-post-password-secret

# GitHub OAuth 配置（可选）
# 在 GitHub Settings -> Developer settings -> OAuth Apps 中创建
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Resend API Key（可选，用于邮件发送）
# 在 https://resend.com 获取
RESEND_API_KEY=re_xxxxxxxxxxxx
